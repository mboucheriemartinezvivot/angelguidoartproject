for out_name, src in sources.items():
    im = Image.open(src).convert("RGB")
    # Resize only very large images for a lighter web package.
    max_w = 1800
    if im.width > max_w:
        ratio = max_w / im.width
        im = im.resize((max_w, int(im.height * ratio)), Image.Resampling.LANCZOS)
    if out_name.endswith(".png"):
        im.save(assets / out_name, "PNG", optimize=True)
    else:
        im.save(assets / out_name, "JPEG", quality=88, optimize=True)

